[project]
enable_telemetry = false
session_timeout = 3600
user_env = []
allow_origins = ["*"]

[features]
# Enabled to support: <details>/<summary> for collapsible Sources block,
# <sup> for superscript citation chips, and HTML-escaped chunk content
# rendering. Chunk-derived content is HTML-escaped before embedding
# (citation_parser.render_sources_section); user input is sanitized by
# the injection_filter pre-LLM. XSS surface kept narrow.
unsafe_allow_html = true
latex = false
edit_message = false

[UI]
name = "{{TENANT_DISPLAY_NAME}}"
description = "Ask questions about {{TENANT_DISPLAY_NAME}}'s knowledge base. Every answer is grounded in source documents; conversations are logged for demo review and deleted after 30 days."
default_collapse_content = false
default_theme = "light"

[meta]
generated_by = "venture-knowledge-chatbot v0"
